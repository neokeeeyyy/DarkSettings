<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:fitsSystemWindows="true">

    <!-- Home Screen -->
    <LinearLayout
        android:id="@+id/homeScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Clock -->
        <TextView
            android:id="@+id/tvClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#FFFFFFFF"
            android:textSize="96sp"
            android:fontFamily="sans-serif-thin"
            android:letterSpacing="-0.05"
            android:gravity="center" />

        <!-- Date -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lunes, 1 de enero"
            android:textColor="#80FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.1"
            android:gravity="center"
            android:layout_marginTop="4dp" />

        <!-- Focus Mode Indicator -->
        <TextView
            android:id="@+id/tvFocusMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FOCUS"
            android:textColor="#40FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.2"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:visibility="gone" />

        <!-- Focus Timer -->
        <TextView
            android:id="@+id/tvFocusTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25:00"
            android:textColor="#FFFFFFFF"
            android:textSize="48sp"
            android:fontFamily="sans-serif-thin"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Music Player -->
        <LinearLayout
            android:id="@+id/musicPlayer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <!-- Track Info -->
            <TextView
                android:id="@+id/tvTrackTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No playing"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="marquee"
                android:singleLine="true"
                android:marqueeRepeatLimit="marquee_forever"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <TextView
                android:id="@+id/tvTrackArtist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#60FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light"
                android:gravity="center"
                android:maxLines="1"
                android:layout_marginTop="2dp" />

            <!-- Progress Bar -->
            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginStart="48dp"
                android:layout_marginEnd="48dp"
                android:progressTint="#FFFFFFFF"
                android:thumbTint="#FFFFFFFF"
                android:progressBackgroundTint="#30FFFFFF"
                android:maxHeight="2dp" />

            <!-- Controls -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <ImageButton
                    android:id="@+id/btnPrevious"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_skip_previous"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:scaleType="centerInside"
                    android:contentDescription="Previous"
                    app:tint="#FFFFFFFF" />

                <ImageButton
                    android:id="@+id/btnPlayPause"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_play"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:scaleType="centerInside"
                    android:contentDescription="Play/Pause"
                    app:tint="#FFFFFFFF"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp" />

                <ImageButton
                    android:id="@+id/btnNext"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_skip_next"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:scaleType="centerInside"
                    android:contentDescription="Next"
                    app:tint="#FFFFFFFF" />

            </LinearLayout>

        </LinearLayout>

        <!-- Pinned Apps (Text Only) -->
        <LinearLayout
            android:id="@+id/pinnedApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Bottom Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/btnAllApps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="all apps"
                android:textColor="#40FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:padding="16dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/btnFocus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="focus"
                android:textColor="#40FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:padding="16dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="settings"
                android:textColor="#40FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:padding="16dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

    </LinearLayout>

    <!-- All Apps Screen (overlay) -->
    <LinearLayout
        android:id="@+id/allAppsScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F0000000"
        android:padding="32dp"
        android:paddingTop="48dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="all apps"
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#10FFFFFF"
            android:hint="search..."
            android:textColorHint="#40FFFFFF"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-light"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAllApps"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:scrollbars="none" />

        <TextView
            android:id="@+id/btnCloseAllApps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="close"
            android:textColor="#40FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:padding="16dp"
            android:layout_gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

    <!-- Focus Mode Screen -->
    <LinearLayout
        android:id="@+id/focusScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F0000000"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="focus mode"
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.2"
            android:layout_marginBottom="48dp" />

        <!-- Timer Display -->
        <TextView
            android:id="@+id/tvFocusCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25:00"
            android:textColor="#FFFFFFFF"
            android:textSize="72sp"
            android:fontFamily="sans-serif-thin"
            android:gravity="center" />

        <!-- Timer Mode Tabs -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="32dp">

            <TextView
                android:id="@+id/btnPomodoro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="pomodoro"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:padding="12dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/btnShortBreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="short break"
                android:textColor="#40FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:padding="12dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/btnLongBreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="long break"
                android:textColor="#40FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:padding="12dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

        <!-- Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="48dp">

            <TextView
                android:id="@+id/btnStartFocus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="start"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@drawable/btn_outline" />

            <TextView
                android:id="@+id/btnResetFocus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="reset"
                android:textColor="#40FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.1"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginStart="16dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnCloseFocus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="close"
            android:textColor="#40FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:padding="16dp"
            android:layout_marginTop="48dp"
            android:background="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

</FrameLayout>
